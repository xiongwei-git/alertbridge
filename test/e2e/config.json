{
  "server": {"listen": ":8080", "body_limit_bytes": 32768},
  "database": {"path": "/var/lib/alertbridge/alertbridge.db", "retention": "720h"},
  "auth": {"timestamp_tolerance": "5m", "nonce_retention": "10m"},
  "dedupe": {"window": "30m"},
  "worker": {
    "poll_interval": "100ms",
    "request_timeout": "2s",
    "lease_duration": "5s",
    "retry_delays": ["100ms", "200ms"],
    "max_attempts": 3
  },
  "admin": {
    "enabled": true,
    "username": "admin",
    "password_file": "/run/secrets/admin-password",
    "master_key_file": "/run/secrets/master-key",
    "session_lifetime": "1h",
    "secure_cookie": false
  },
  "clients": {
    "e2e-client": {
      "enabled": true,
      "secret_file": "/run/secrets/client-e2e",
      "allowed_routes": ["infrastructure"],
      "rate_limit_per_minute": 20
    }
  },
  "channels": {
    "feishu.test": {
      "type": "feishu",
      "enabled": true,
      "webhook_file": "/run/secrets/feishu-webhook",
      "signing_secret_file": "/run/secrets/feishu-signing",
      "message_type": "card",
      "keyword": "AlertBridge",
      "allowed_hosts": ["mockfeishu"],
      "allow_insecure_http": true
    }
  },
  "routes": {
    "infrastructure": {
      "critical": ["feishu.test"],
      "warning": ["feishu.test"],
      "info": ["feishu.test"]
    }
  }
}
